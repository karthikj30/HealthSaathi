# Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Supabase Database URL (get from Project Settings > Database)
# Important: URL-encode special characters in password (example: @ => %40)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# If your environment cannot reach IPv6 addresses, use Supabase Pooler connection string instead.
# Example format only (copy exact value from Supabase Dashboard > Connect > Pooler):
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase Project URL (for future API calls if needed)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Supabase Anon Key (for client-side if needed)
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# AssemblyAI API key for voice transcription
ASSEMBLYAI_API_KEY=[YOUR-ASSEMBLYAI-API-KEY]

# OCR.space API key for document OCR + simplification analysis
OCR_API_KEY=[YOUR-OCR-API-KEY]